#: darkadmin.php includes/settings-page.php
msgid "DarkAdmin"
msgstr "DarkAdmin"

#: includes/settings-page.php
msgid "Dark theme for the WordPress backend"
msgstr "Dark theme for the WordPress backend"

#: darkadmin.php
msgid "Settings"
msgstr "Settings"

#: includes/settings-page.php
msgid "General"
msgstr "General"

#: includes/settings-page.php
msgid "Enable Dark Mode"
msgstr "Enable Dark Mode"

#: includes/settings-page.php
msgid "Enables the dark theme for all admin pages. Administrators always see dark mode when this is active."
msgstr "Enables the dark theme for all admin pages. Administrators always see dark mode when this is active."

#: includes/settings-page.php
msgid "Auto Dark Mode"
msgstr "Auto Dark Mode"

#: includes/settings-page.php
msgid "Automatically darkens bright backgrounds and lightens dark text from unknown plugins. Requires Dark Mode to be active."
msgstr "Automatically darkens bright backgrounds and lightens dark text from unknown plugins. Requires Dark Mode to be active."

#: includes/settings-page.php
msgid "Active"
msgstr "Active"

#: includes/settings-page.php
msgid "Inactive"
msgstr "Inactive"

#: includes/settings-page.php
msgid "User Access"
msgstr "User Access"

#: includes/settings-page.php
msgid "Select which non-admin users should see dark mode. Administrators always have dark mode active. Leave all unchecked to apply dark mode to all users."
msgstr "Select which non-admin users should see dark mode. Administrators always have dark mode active. Leave all unchecked to apply dark mode to all users."

#: includes/settings-page.php
msgid "Administrators are not listed here — they always have dark mode active."
msgstr "Administrators are not listed here — they always have dark mode active."

#: includes/settings-page.php
msgid "Color Customization"
msgstr "Color Customization"

#: includes/settings-page.php
msgid "Customize every color token individually. Changes are previewed live."
msgstr "Customize every color token individually. Changes are previewed live."

#: includes/settings-page.php
msgid "Export Palette"
msgstr "Export Palette"

#: includes/settings-page.php
msgid "Import Palette"
msgstr "Import Palette"

#: includes/settings-page.php
msgid "Restore Default Colors"
msgstr "Restore Default Colors"

#: includes/settings-page.php
msgid "Custom CSS"
msgstr "Custom CSS"

#: includes/settings-page.php
msgid "Add your own CSS here, loaded after the dark mode stylesheet. All CSS variables are available."
msgstr "Add your own CSS here, loaded after the dark mode stylesheet. All CSS variables are available."

#: includes/settings-page.php
msgid "Available CSS Variables"
msgstr "Available CSS Variables"

#: includes/settings-page.php
msgid "Click to copy"
msgstr "Click to copy"

#: includes/settings-page.php
msgid "Save Settings"
msgstr "Save Settings"

#: darkadmin.php
msgid "✓ Dark Mode is active. Settings have been saved."
msgstr "✓ Dark Mode is active. Settings have been saved."

#: darkadmin.php
msgid "✓ Settings saved. Dark Mode is disabled."
msgstr "✓ Settings saved. Dark Mode is disabled."
