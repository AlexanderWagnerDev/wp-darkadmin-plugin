#: darkadmin.php
msgid "DarkAdmin"
msgstr "DarkAdmin"

#: darkadmin.php
msgid "Dark theme for the WordPress backend"
msgstr "Dunkles Theme f\u00fcr das WordPress-Backend"

#: darkadmin.php
msgid "Settings"
msgstr "Einstellungen"

#: darkadmin.php
msgid "General"
msgstr "Allgemein"

#: darkadmin.php
msgid "Enable Dark Mode"
msgstr "Dark Mode aktivieren"

#: darkadmin.php
msgid "Enables the dark theme for all admin pages."
msgstr "Aktiviert das dunkle Design f\u00fcr alle Admin-Seiten."

#: darkadmin.php
msgid "Auto Dark Mode"
msgstr "Auto Dark Mode"

#: darkadmin.php
msgid "Automatically darkens bright backgrounds and lightens dark text from unknown plugins. Requires Dark Mode to be active."
msgstr "Verdunkelt automatisch helle Hintergr\u00fcnde und erhellt dunklen Text unbekannter Plugins. Setzt aktiven Dark Mode voraus."

#: darkadmin.php
msgid "Active"
msgstr "Aktiv"

#: darkadmin.php
msgid "Inactive"
msgstr "Inaktiv"

#: darkadmin.php
msgid "Color Customization"
msgstr "Farbanpassung"

#: darkadmin.php
msgid "Customize every color token individually. Changes are applied globally via CSS variables."
msgstr "Passe jeden Farbwert individuell an. \u00c4nderungen werden global \u00fcber CSS-Variablen angewendet."

#: darkadmin.php
msgid "Background (Base)"
msgstr "Hintergrund (Basis)"

#: darkadmin.php
msgid "Surface 1 (Cards / Tables)"
msgstr "Fl\u00e4che 1 (Karten / Tabellen)"

#: darkadmin.php
msgid "Surface 2 (Inputs)"
msgstr "Fl\u00e4che 2 (Eingabefelder)"

#: darkadmin.php
msgid "Surface 3 (Hover)"
msgstr "Fl\u00e4che 3 (Hover)"

#: darkadmin.php
msgid "Border Color"
msgstr "Rahmenfarbe"

#: darkadmin.php
msgid "Primary Text"
msgstr "Prim\u00e4rer Text"

#: darkadmin.php
msgid "Muted Text"
msgstr "Ged\u00e4mpfter Text"

#: darkadmin.php
msgid "Soft Text (Row Actions)"
msgstr "Weicher Text (Zeilen-Aktionen)"

#: darkadmin.php
msgid "Link Color"
msgstr "Linkfarbe"

#: darkadmin.php
msgid "Primary / Buttons"
msgstr "Prim\u00e4rfarbe / Buttons"

#: darkadmin.php
msgid "Success"
msgstr "Erfolgsmeldung"

#: darkadmin.php
msgid "Warning"
msgstr "Warnung"

#: darkadmin.php
msgid "Danger / Error"
msgstr "Fehler / Gefahr"

#: darkadmin.php
msgid "Restore Default Colors"
msgstr "Standardfarben wiederherstellen"

#: darkadmin.php
msgid "Custom CSS"
msgstr "Eigenes CSS"

#: darkadmin.php
msgid "Add your own CSS here, loaded after the dark mode stylesheet. All CSS variables are available."
msgstr "F\u00fcge hier dein eigenes CSS hinzu, das nach dem Dark-Mode-Stylesheet geladen wird. Alle CSS-Variablen sind verf\u00fcgbar."

#: darkadmin.php
msgid "Available CSS Variables"
msgstr "Verf\u00fcgbare CSS-Variablen"

#: darkadmin.php
msgid "Click to copy"
msgstr "Klicken zum Kopieren"

#: darkadmin.php
msgid "Save Settings"
msgstr "Einstellungen speichern"

#: darkadmin.php
msgid "\u2713 Dark Mode is active. Settings have been saved."
msgstr "\u2713 Dark Mode ist aktiv. Die Einstellungen wurden gespeichert."

#: darkadmin.php
msgid "\u2713 Settings saved. Dark Mode is disabled."
msgstr "\u2713 Einstellungen gespeichert. Dark Mode ist deaktiviert."
