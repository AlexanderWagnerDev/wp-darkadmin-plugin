#: wp-admin-dark-mode.php
msgid "WP Admin Dark Mode"
msgstr "WP Admin Dark Mode"

#: wp-admin-dark-mode.php
msgid "Dark theme for the WordPress backend"
msgstr "Dunkles Theme für das WordPress-Backend"

#: wp-admin-dark-mode.php
msgid "Settings"
msgstr "Einstellungen"

#: wp-admin-dark-mode.php
msgid "General"
msgstr "Allgemein"

#: wp-admin-dark-mode.php
msgid "Enable Dark Mode"
msgstr "Dark Mode aktivieren"

#: wp-admin-dark-mode.php
msgid "Enables the dark theme for all admin pages."
msgstr "Aktiviert das dunkle Design für alle Admin-Seiten."

#: wp-admin-dark-mode.php
msgid "Active"
msgstr "Aktiv"

#: wp-admin-dark-mode.php
msgid "Inactive"
msgstr "Inaktiv"

#: wp-admin-dark-mode.php
msgid "Color Customization"
msgstr "Farbanpassung"

#: wp-admin-dark-mode.php
msgid "Customize the dark mode colors individually. The defaults are based on the WordPress sidebar palette."
msgstr "Passe die Dark-Mode-Farben individuell an. Die Standardwerte orientieren sich an der WordPress-Sidebar-Palette."

#: wp-admin-dark-mode.php
msgid "Background Color (Base)"
msgstr "Hintergrundfarbe (Basis)"

#: wp-admin-dark-mode.php
msgid "Card / Content Area"
msgstr "Karten- / Contentbereich"

#: wp-admin-dark-mode.php
msgid "Border Color"
msgstr "Rahmenfarbe"

#: wp-admin-dark-mode.php
msgid "Text Color"
msgstr "Textfarbe"

#: wp-admin-dark-mode.php
msgid "Muted Text Color"
msgstr "Gedämpfte Textfarbe"

#: wp-admin-dark-mode.php
msgid "Link Color"
msgstr "Linkfarbe"

#: wp-admin-dark-mode.php
msgid "Primary Color (Buttons)"
msgstr "Primärfarbe (Buttons)"

#: wp-admin-dark-mode.php
msgid "Success Color"
msgstr "Erfolgsfarbe"

#: wp-admin-dark-mode.php
msgid "Warning Color"
msgstr "Warnfarbe"

#: wp-admin-dark-mode.php
msgid "Restore Default Colors"
msgstr "Standardfarben wiederherstellen"

#: wp-admin-dark-mode.php
msgid "Custom CSS"
msgstr "Eigenes CSS"

#: wp-admin-dark-mode.php
msgid "Add your own CSS here, loaded after the dark mode stylesheet. You can use the CSS variables (--adm-bg, --adm-card, etc.) directly."
msgstr "Füge hier dein eigenes CSS hinzu, das nach dem Dark-Mode-Stylesheet geladen wird. Du kannst die CSS-Variablen (--adm-bg, --adm-card, etc.) direkt verwenden."

#: wp-admin-dark-mode.php
msgid "Save Settings"
msgstr "Einstellungen speichern"

#: wp-admin-dark-mode.php
msgid "✓ Dark Mode is active. Settings have been saved."
msgstr "✓ Dark Mode ist aktiv. Die Einstellungen wurden gespeichert."

#: wp-admin-dark-mode.php
msgid "✓ Settings saved. Dark Mode is disabled."
msgstr "✓ Einstellungen gespeichert. Dark Mode ist deaktiviert."
