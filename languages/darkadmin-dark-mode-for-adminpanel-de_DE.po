#: darkadmin.php includes/settings-page.php
msgid "DarkAdmin"
msgstr "DarkAdmin"

#: includes/settings-page.php
msgid "Dark theme for the WordPress backend"
msgstr "Dunkles Theme für das WordPress-Backend"

#: darkadmin.php
msgid "Settings"
msgstr "Einstellungen"

#: includes/settings-page.php
msgid "Active"
msgstr "Aktiv"

#: includes/settings-page.php
msgid "Inactive"
msgstr "Inaktiv"

#: includes/settings-page.php
msgid "General"
msgstr "Allgemein"

#: includes/settings-page.php
msgid "Enable Dark Mode"
msgstr "Dark Mode aktivieren"

#: includes/settings-page.php
msgid "Enables the dark theme for all admin pages. Administrators always see dark mode when this is active."
msgstr "Aktiviert das dunkle Design für alle Admin-Seiten. Administratoren sehen den Dark Mode immer, wenn er aktiviert ist."

#: includes/settings-page.php
msgid "Auto Dark Mode"
msgstr "Auto Dark Mode"

#: includes/settings-page.php
msgid "Automatically darkens bright backgrounds and lightens dark text from unknown plugins. Requires Dark Mode to be active."
msgstr "Verdunkelt automatisch helle Hintergründe und erhellt dunklen Text unbekannter Plugins. Setzt aktiven Dark Mode voraus."

#: includes/settings-page.php
msgid "Preset Themes"
msgstr "Preset-Themes"

#: includes/settings-page.php
msgid "Choose a preset to load its color palette. You can further customize colors below after loading."
msgstr "Wähle ein Preset aus, um dessen Farbpalette zu laden. Farben können anschließend weiter angepasst werden."

#: includes/settings-page.php
msgid "Default"
msgstr "Standard"

#: includes/settings-page.php
msgid "Classic WP 6.x dark theme"
msgstr "Klassisches WP 6.x Dark-Theme"

#: includes/settings-page.php
msgid "Modern"
msgstr "Modern"

#: includes/settings-page.php
msgid "WP Modern design language (dark)"
msgstr "WP Modern Design Language (dunkel)"

#: includes/settings-page.php
msgid "Load Preset"
msgstr "Preset laden"

#: includes/settings-page.php
msgid "✓ Active"
msgstr "✓ Aktiv"

#: includes/settings-page.php
msgid "Preview"
msgstr "Vorschau"

#: includes/settings-page.php
msgid "User Access"
msgstr "Benutzerzugriff"

#: includes/settings-page.php
msgid "All Users"
msgstr "Alle Benutzer"

#: includes/settings-page.php
msgid "Dark mode applies to everyone."
msgstr "Dark Mode gilt für alle Benutzer."

#: includes/settings-page.php
msgid "Include"
msgstr "Einschließen"

#: includes/settings-page.php
msgid "Only selected users get dark mode."
msgstr "Nur ausgewählte Benutzer erhalten den Dark Mode."

#: includes/settings-page.php
msgid "Exclude"
msgstr "Ausschließen"

#: includes/settings-page.php
msgid "Everyone except selected users gets dark mode."
msgstr "Alle außer den ausgewählten Benutzern erhalten den Dark Mode."

#: includes/settings-page.php
msgid "Administrators are not listed here — they always have dark mode active."
msgstr "Administratoren werden hier nicht angezeigt — sie haben den Dark Mode immer aktiv."

#: includes/settings-page.php
msgid "No non-administrator users found. Create additional users to manage their dark mode access here."
msgstr "Keine Nicht-Administrator-Benutzer gefunden. Erstelle weitere Benutzer, um deren Dark-Mode-Zugriff hier zu verwalten."

#: includes/settings-page.php
msgid "Color Customization"
msgstr "Farbanpassung"

#: includes/settings-page.php
msgid "Customize every color token individually. Changes are previewed live."
msgstr "Passe jeden Farbwert individuell an. Änderungen werden sofort als Vorschau angezeigt."

#: includes/settings-page.php
msgid "Export Palette"
msgstr "Palette exportieren"

#: includes/settings-page.php
msgid "Import Palette"
msgstr "Palette importieren"

#: includes/settings-page.php
msgid "Restore Default Colors"
msgstr "Standardfarben wiederherstellen"

#: includes/settings-page.php
msgid "Available CSS Variables"
msgstr "Verfügbare CSS-Variablen"

#: includes/settings-page.php
msgid "Click to copy"
msgstr "Klicken zum Kopieren"

#: includes/settings-page.php
msgid "Custom CSS"
msgstr "Eigenes CSS"

#: includes/settings-page.php
msgid "Add your own CSS here, loaded after the dark mode stylesheet. All CSS variables are available."
msgstr "Füge hier dein eigenes CSS hinzu, das nach dem Dark-Mode-Stylesheet geladen wird. Alle CSS-Variablen sind verfügbar."

#: includes/settings-page.php
msgid "Save Settings"
msgstr "Einstellungen speichern"

#: darkadmin.php
msgid "✓ Dark Mode is active. Settings have been saved."
msgstr "✓ Dark Mode ist aktiv. Die Einstellungen wurden gespeichert."

#: darkadmin.php
msgid "✓ Settings saved. Dark Mode is disabled."
msgstr "✓ Einstellungen gespeichert. Dark Mode ist deaktiviert."

